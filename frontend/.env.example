# .env.example — Frontend environment variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and MUST never be committed.
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# URL of the backend API (Cloudflare Worker)
# Local development: matches wrangler dev default port
VITE_API_URL=http://localhost:8787

# Bearer tokens for each tenant.
# These must match the values set in the backend's .dev.vars (local)
# or via `wrangler secret put` (production).
#
# Clients send: Authorization: Bearer <token>
VITE_TENANT_A_TOKEN=replace-with-tenant-a-token
VITE_TENANT_B_TOKEN=replace-with-tenant-b-token
